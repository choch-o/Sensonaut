# Sensonaut .gitignore

# =============================================================================
# Python
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE settings
.idea/
.vscode/
*.swp
*.swo
*~

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# pytest
.pytest_cache/

# mypy
.mypy_cache/

# =============================================================================
# Project-specific
# =============================================================================

# Training outputs
python/checkpoints/
python/runs/
python/videos/
python/test_logs/
python/logs/
python/models/

# Wandb
wandb/

# Large data files (keep structure, ignore contents)
python/analysis/data/*.zip
python/maps/maps.json

# Temporary files
*.tmp
*.temp
*.bak

# =============================================================================
# Unity (additional to unity/.gitignore)
# =============================================================================

# Unity generated
unity/Library/
unity/Temp/
unity/Obj/
unity/Build/
unity/Builds/
unity/Logs/
unity/UserSettings/
unity/MemoryCaptures/

# Autogenerated VS/MD/Rider solution and target files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Recording files (can be large)
unity/*.wav
unity/Assets/StreamingAssets/*/

# =============================================================================
# OS-specific
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

.claude/